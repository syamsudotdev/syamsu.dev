:3000 {
	root * /usr/share/caddy
	encode zstd gzip

	@assets path /assets/*
	@nonassets not path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	header @nonassets Cache-Control "public, max-age=0, must-revalidate"

	try_files {path} {path}.html {path}/index.html
	file_server

	handle_errors {
		rewrite * /404.html
		file_server
	}
}
